{
  "name": "@careercompass/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@careercompass/constants": "workspace:*",
    "@careercompass/types": "workspace:*",
    "@careercompass/validators": "workspace:*",
    "@clerk/clerk-sdk-node": "^5.0.48",
    "@pinecone-database/pinecone": "^2.2.2",
    "@prisma/client": "^5.17.0",
    "@sentry/node": "^8.26.0",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.12.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pino": "^9.3.2",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "resend": "^3.5.0",
    "socket.io": "^4.7.5",
    "stripe": "^16.3.0",
    "svix": "^1.24.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.15",
    "@types/pdf-parse": "^1.1.4",
    "@vitest/coverage-v8": "^2.0.5",
    "prisma": "^5.17.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsup": "^8.2.4",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
